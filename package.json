{
  "name": "prism",
  "version": "0.1.1",
  "description": "Prism — a developer browser: split panes, per-pane viewport control, interaction & route mirroring, a cross-pane network diff, and a built-in SSH dev proxy.",
  "main": "./out/main/index.js",
  "author": "Moravec",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fallow": "fallow",
    "analyze": "fallow",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,svelte,js,mjs,cjs,json,css,html}": "prettier --write"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/node": "^20.14.0",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "fallow": "^2.99.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.moravec.prism",
    "productName": "Prism",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "afterSign": "build/notarize.cjs",
    "publish": {
      "provider": "github",
      "owner": "Moravec-Pty-Ltd",
      "repo": "prism"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/spline-sans-mono": "^5.2.8",
    "@pierre/diffs": "^1.2.11",
    "electron-updater": "^6.3.9",
    "phosphor-svelte": "^3.1.0",
    "pixelmatch": "^7.2.0"
  }
}
